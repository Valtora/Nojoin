# Core
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nojoin
REDIS_PASSWORD=change_this_before_remote_access
WEB_APP_URL=https://localhost:14443
ALLOWED_ORIGINS=
FIRST_RUN_PASSWORD=change_this_before_first_start
DATA_ENCRYPTION_KEY=change_this_to_a_long_random_secret

# Worker
WHISPER_ENABLE_WORD_TIMESTAMPS=true
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Optional
DEFAULT_TIMEZONE=UTC
HF_TOKEN=
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_API_URL=http://host.docker.internal:11434

# Calendar OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=common
